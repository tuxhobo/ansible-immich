# {{ immich_compose_base }}/docker-compose.yml
# Managed by Ansible — do not edit manually.
# Source: roles/immich_config/templates/docker-compose.yml.j2

name: immich

services:

  immich-server:
    image: ghcr.io/immich-app/immich-server:${IMMICH_VERSION}
    container_name: immich_server
    restart: unless-stopped
    depends_on:
      - redis
      - database
    ports:
      - "{{ immich_server_port }}:3001"
    environment:
      - DB_HOSTNAME=${DB_HOSTNAME}
      - DB_DATABASE_NAME=${DB_DATABASE_NAME}
      - DB_USERNAME=${DB_USERNAME}
      - DB_PASSWORD=${DB_PASSWORD}
      - JWT_SECRET=${JWT_SECRET}
      - REDIS_HOSTNAME=immich_redis
    volumes:
      # Upload libraries — one per user, on NFS
{% for user in immich_users if user.library_path is not none %}
      - /mnt/nfs/immich/{{ user.username }}:/usr/src/app/upload/{{ user.username }}:rw
{% endfor %}
      # Archive — read-only, owned by immich-archive service account
      - /mnt/nfs/images:/usr/src/app/external-library:ro
    user: "{{ immich_uid }}:{{ immich_gid }}"

  immich-machine-learning:
    image: ghcr.io/immich-app/immich-machine-learning:${IMMICH_VERSION}
    container_name: immich_machine_learning
    restart: unless-stopped
    volumes:
      - {{ immich_compose_base }}/data/model-cache:/cache
    user: "{{ immich_uid }}:{{ immich_gid }}"

  redis:
    image: docker.io/redis:6.2-alpine
    container_name: immich_redis
    restart: unless-stopped
    healthcheck:
      test: redis-cli ping
      interval: 10s
      timeout: 5s
      retries: 5

  database:
    image: docker.io/tensorchord/pgvecto-rs:pg14-v0.2.0
    container_name: immich_postgres
    restart: unless-stopped
    environment:
      - POSTGRES_DB=${DB_DATABASE_NAME}
      - POSTGRES_USER=${DB_USERNAME}
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - POSTGRES_INITDB_ARGS=--data-checksums
    volumes:
      # Local disk only — never NFS. Postgres requires direct filesystem semantics.
      - {{ immich_compose_base }}/data/db:/var/lib/postgresql/data
    healthcheck:
      test: >-
        pg_isready --dbname="${DB_DATABASE_NAME}" --username="${DB_USERNAME}"
        || exit 1
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
